{
  "enabled": true,
  "name": "Protect dev and main branches",
  "description": "Blocks file write operations when the current git branch is dev or main. All changes must be made on a feature/, fix/, or bug/ branch.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Before proceeding with this write operation, run `git branch --show-current` to check the current branch. If the current branch is `dev` or `main`, you MUST refuse the write operation and tell the user: \"This branch is protected. Please create a feature, fix, or bug branch before making changes. Example: git checkout -b feature/your-feature-name\". Do NOT proceed with the write. If the current branch is anything other than `dev` or `main` (e.g. feature/*, fix/*, bug/*), approve the operation and proceed normally without any message."
  }
}