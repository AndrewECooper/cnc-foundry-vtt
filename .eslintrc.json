{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "extends": ["eslint:recommended","plugin:jsdoc/recommended"],
    "overrides": [],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins":["@typescript-eslint","jsdoc"],
    "ignorePatterns": ["dist/*"],
    "rules": {
        "quotes": ["warn", "single"],
        "no-prototype-builtins": ["off"],
        "no-unused-vars": ["off"],
        "no-undef": ["off"]
    }
}