{
  "private": true,
  "name": "castles-and-crusades",
  "version": "0.0.1",
  "description": "Troll Lord Games Castles & Crusades game system for FoundryVTT",
  "homepage": "https://gitlab.com/troll-lord/foundry-vtt/ruleset/castles-and-crusades",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/troll-lord/foundry-vtt/ruleset/castles-and-crusades"
  },
  "bugs": {
    "url": "https://gitlab.com/troll-lord/foundry-vtt/ruleset/castles-and-crusades/-/issues"
  },
  "scripts": {
    "build": "gulp buildAll",
    "build:clean": "gulp cleanPacks",
    "build:css": "gulp buildCSS",
    "build:db": "gulp compilePacks",
    "build:json": "gulp extractPacks",
    "build:watch": "gulp",
    "clean": "rimraf .cache",
    "update-manifest": "node ./utils/update-manifest.mjs",
    "check:lint": "eslint --ext .ts,.js,.mjs .",
    "lint": "gulp lint",
    "lint:fix": "gulp lint --fix",
    "prepare": "husky install",
    "pretty-staged": "pretty-quick --staged --patern '**/*.!(hbs)'"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.15.4",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "chalk": "^5.2.0",
    "eslint-plugin-deprecation": "^1.4.1",
    "eslint-plugin-jsdoc": "^39.3.3",
    "fancy-log": "^2.0.0",
    "fs": "^0.0.1-security",
    "gulp": "^4.0.2",
    "gulp-eslint-new": "^1.6.0",
    "gulp-if": "^3.0.0",
    "gulp-less": "^5.0.0",
    "husk": "^0.5.3",
    "merge-stream": "^2.0.0",
    "nedb": "^1.8.0",
    "path": "^0.12.7",
    "prettier": "^2.8.8",
    "pretty-quick": "^3.1.3",
    "rimraf": "^5.0.0",
    "rollup": "^2.77.0",
    "through2": "^4.0.2",
    "yargs": "^17.7.2"
  }
}
